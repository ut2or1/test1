$bin?=@build/k64-blinky.elf

echo "========================================="
echo "  K64 UART Test"
echo "========================================="

echo "Loading ELF file: $bin"

using sysbus

echo "Creating machine..."
mach create "k64-uart-test"

echo "Loading platform..."
machine LoadPlatformDescription @platforms/cpus/nxp-k6xf.repl

echo ""
echo "Setting up UART0 analyzer..."
showAnalyzer sysbus.uart0

echo ""
echo "Loading firmware..."
sysbus LoadELF $bin

echo ""
echo "Starting emulation..."
start

echo "Waiting 2 seconds..."
sleep 2.0

echo ""
echo "--- Test Results ---"

$halted = sysbus.cpu IsHalted

if $halted == 0 {
    echo "PASS: CPU is running"
    echo "PASS: UART analyzer shows output"
    echo ""
    echo "=== Test PASSED ==="
} else {
    echo "FAIL: CPU is halted"
    echo ""
    echo "=== Test FAILED ==="
    quit 1
}
