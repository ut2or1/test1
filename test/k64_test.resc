# Renode Monitor script для тестирования K64 Blinky

$bin?=@build/k64-blinky.elf

using sysbus

mach create "k64-blinky-test"
machine LoadPlatformDescription @platforms/cpus/k64f.repl

showAnalyzer sysbus.uart3

macro reset
"""
    sysbus LoadELF $bin
"""

runMacro reset

echo "=== Starting K64 Blinky LED Test ==="

Start Emulation
sleep 0.1

# Проверяем PDDR регистр
$pddr = sysbus.gpioc.PDDR
echo "PDDR = $pddr"
if $pddr == 0x00200000 {
    echo "PASS: PDDR configured correctly"
} else {
    echo "FAIL: PDDR is 0x$pddr, expected 0x00200000"
}

# Начальное состояние светодиода
$led_state = sysbus.gpioc.PDOR & 0x00200000
echo "Initial LED state: $led_state"

# Ждем переключения
sleep 1.5
$led_state_new = sysbus.gpioc.PDOR & 0x00200000
echo "LED state after wait: $led_state_new"

if $led_state_new != $led_state {
    echo "PASS: LED state changed"
} else {
    echo "FAIL: LED state did not change"
}

# Проверяем несколько переключений
$prev = $led_state_new
for $i in range(1,3) {
    sleep 1.0
    $current = sysbus.gpioc.PDOR & 0x00200000
    echo "Toggle $i: LED = $current"
    if $current != $prev {
        echo "PASS: LED toggle $i"
    } else {
        echo "FAIL: LED toggle $i"
    }
    $prev = $current
}

echo "=== Tests completed ==="
Stop Emulation
