$bin?=@build/k64-blinky.elf
$platform?=@test/frdm_k64f.resc

echo "========================================="
echo "  K64 Blinky LED Test"
echo "========================================="

echo "Loading ELF file: $bin"
echo "Loading platform from: $platform"

using sysbus

echo "Creating machine..."
mach create "k64-blinky-test"

echo "Loading platform description..."
machine LoadPlatformDescription $platform

echo ""
echo "Loading firmware..."
sysbus LoadELF $bin

echo ""
echo "Starting emulation..."
start

sleep 1.0

echo ""
echo "--- GPIO Configuration Check ---"

$pddr = sysbus.gpioc.PDDR
echo "PDDR register: $pddr"

if $pddr != 0 {
    echo "PASS: GPIO port C initialized (PDDR = $pddr)"
    
    $led_mask = 0x00200000
    if $pddr & $led_mask {
        echo "PASS: PTC21 configured as output"
    } else {
        echo "FAIL: PTC21 not configured as output"
    }
} else {
    echo "FAIL: GPIO port C not initialized (PDDR = 0)"
}

echo ""
echo "--- LED Blink Test ---"
echo "Monitoring LED state for 5 seconds..."
echo ""

$toggles = 0
$prev = -1

for $i in range(1,6) {
    sleep 1.0
    $pdor = sysbus.gpioc.PDOR
    $led = $pdor & 0x00200000
    
    if $led == 0 {
        echo "Second $i: LED = OFF"
    } else {
        echo "Second $i: LED = ON"
    }
    
    if $prev != -1 {
        if $led != $prev {
            echo "  -> LED TOGGLED!"
            $toggles = $toggles + 1
        }
    }
    $prev = $led
}

echo ""
echo "--- Test Results ---"
echo "LED toggles: $toggles"

if $toggles >= 2 {
    echo "PASS: LED is blinking correctly"
} else {
    echo "FAIL: LED did not toggle enough times"
}

echo ""
echo "=== Test completed ==="
stop
