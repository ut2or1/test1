$bin?=@build/k64-blinky.elf

echo "Loading ELF file: $bin"

using sysbus

echo "Creating machine..."
mach create "k64-blinky-test"

echo "Loading platform description..."
machine LoadPlatformDescription @platforms/cpus/nxp-k6xf.repl

echo "Available UARTs and peripherals:"
peripherals

showAnalyzer sysbus.uart0

echo "Loading firmware..."
sysbus LoadELF $bin

echo "=== Starting K64 Blinky LED Test ==="

echo "Starting emulation..."
Start Emulation
sleep 0.5

echo "Checking GPIO configuration..."
$pddr = sysbus.gpioc.PDDR
echo "PDDR = $pddr"

if $pddr != 0x0 {
    echo "PASS: GPIO initialized (PDDR = $pddr)"
} else {
    echo "FAIL: GPIO not initialized (PDDR = $pddr)"
}

echo "Monitoring LED state for 5 seconds..."
$prev = 0
for $i in range(1,6) {
    sleep 1.0
    $pdor = sysbus.gpioc.PDOR
    $led = $pdor & 0x00200000
    echo "Second $i: PDOR = $pdor, LED = $led"
    
    if $led != $prev {
        echo "  LED CHANGED!"
    }
    $prev = $led
}

echo "=== Test completed ==="
Stop Emulation
