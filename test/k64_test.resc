$bin?=@build/k64-blinky.elf

echo "========================================="
echo "  K64 UART Test"
echo "========================================="

echo "Loading ELF file: $bin"

using sysbus

echo "Creating machine..."
mach create "k64-uart-test"

echo "Loading platform..."
machine LoadPlatformDescription @platforms/cpus/nxp-k6xf.repl

echo ""
echo "Setting up UART0 analyzer..."
showAnalyzer sysbus.uart0

echo ""
echo "Loading firmware..."
sysbus LoadELF $bin

echo ""
echo "Starting emulation..."
start

echo "Waiting for boot message..."
sleep 0.5

echo ""
echo "--- Checking UART output ---"

$pass = 0

# Проверяем наличие приветственного сообщения
$data = sysbus.uart0 Data
if $data != "" {
    echo "PASS: UART0 is transmitting"
    echo "  Received: $data"
    $pass = 1
} else {
    echo "FAIL: No UART data received"
}

sleep 1.0

$data = sysbus.uart0 Data
if $data != "" {
    echo "  Data: $data"
}

echo ""
echo "--- Test Results ---"
if $pass == 1 {
    echo "PASS: K64 UART test passed!"
} else {
    echo "FAIL: No UART output detected"
}

echo ""
echo "=== Test completed ==="
