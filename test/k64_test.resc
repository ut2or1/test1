$bin?=@build/k64-blinky.elf

echo "========================================="
echo "  K64 Blinky LED Test"
echo "========================================="

echo "Loading ELF file: $bin"

using sysbus

echo "Creating machine..."
mach create "k64-blinky-test"

echo "Loading platform description..."
machine LoadPlatformDescription @platforms/cpus/nxp-k6xf.repl

echo ""
echo "Available peripherals:"
peripherals

echo ""
echo "Setting up UART analyzer..."
showAnalyzer sysbus.uart0

echo ""
echo "Loading firmware..."
sysbus LoadELF $bin

echo ""
echo "========================================="
echo "  Starting K64 Blinky LED Test"
echo "========================================="

echo "Starting emulation..."
start

echo "Waiting for initialization..."
sleep 0.5

echo ""
echo "--- GPIO Configuration Check ---"

sysbus ReadDoubleWord 0x400FF154 $pddr
echo "PDDR register: $pddr"

if $pddr != 0 {
    echo "PASS: GPIO port C initialized"
    echo "  PDDR value: $pddr"
    
    sysbus ReadDoubleWord 0x400FF154 $pddr_val
    $led_mask = 0x00200000
    
    if $pddr_val & $led_mask {
        echo "PASS: PTC21 configured as output"
    } else {
        echo "FAIL: PTC21 not configured as output"
    }
} else {
    echo "FAIL: GPIO port C not initialized (PDDR = 0)"
}

echo ""
echo "--- LED Blink Test ---"
echo "Monitoring LED state for 5 seconds..."
echo ""

$prev = -1
$toggles = 0

for $i in range(1,6) {
    sleep 1.0
    
    sysbus ReadDoubleWord 0x400FF134 $pdor
    $led = $pdor & 0x00200000
    
    if $led == 0 {
        echo "Second $i: PDOR=$pdor, LED=OFF"
    } else {
        echo "Second $i: PDOR=$pdor, LED=ON"
    }
    
    if $prev != -1 {
        if $led != $prev {
            echo "  -> LED TOGGLED!"
            $toggles = $toggles + 1
        }
    }
    $prev = $led
}

echo ""
echo "--- Test Results ---"
echo "LED toggles detected: $toggles"

if $toggles >= 2 {
    echo "PASS: LED is blinking correctly"
} else {
    if $toggles == 0 {
        echo "FAIL: LED did not toggle"
    } else {
        echo "WARNING: LED toggled only $toggles time(s)"
    }
}

echo ""
echo "--- GPIO Final State ---"
sysbus ReadDoubleWord 0x400FF154 $pddr_final
sysbus ReadDoubleWord 0x400FF134 $pdor_final
echo "Final PDDR: $pddr_final"
echo "Final PDOR: $pdor_final"

$led_final = $pdor_final & 0x00200000
if $led_final == 0 {
    echo "Final LED state: OFF"
} else {
    echo "Final LED state: ON"
}

echo ""
echo "========================================="
echo "  Test completed"
echo "========================================="
stop
