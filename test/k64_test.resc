$bin?=@build/k64-blinky.elf

# Подавляем предупреждения
logLevel -1 sysbus
logLevel -1 cpu

echo "========================================="
echo "  K64 UART Test"
echo "========================================="

echo "Loading ELF file: $bin"

using sysbus

echo "Creating machine..."
mach create "k64-uart-test"

echo "Loading platform..."
machine LoadPlatformDescription @platforms/cpus/nxp-k6xf.repl

echo ""
echo "Setting up UART0 analyzer..."
showAnalyzer sysbus.uart0

echo ""
echo "Loading firmware..."
sysbus LoadELF $bin

echo ""
echo "Starting emulation..."
start

echo "Waiting for UART output..."
sleep 1.0

echo ""
echo "--- Test Results ---"

$result = sysbus.uart0 Data

if $result != "" {
    echo "PASS: UART0 is transmitting data"
    echo "First data: $result"
    $test_passed = 1
} else {
    echo "FAIL: No UART data received"
    $test_passed = 0
}

echo ""
if $test_passed == 1 {
    echo "=== Test PASSED ==="
} else {
    echo "=== Test FAILED ==="
}

if $test_passed == 0 {
    quit 1
}
